---
const year = new Date().getFullYear();
---

<footer
  class="mt-auto border-t py-8"
  style="border-color: var(--color-border); color: var(--color-text-muted);"
>
  <div class="container flex flex-col items-center gap-4 text-sm md:flex-row md:justify-between">
    <p>© {year} cruel.run · Built with Astro</p>
    <div class="flex items-center gap-4">
      <a
        href="https://github.com/Perisiguiendo"
        target="_blank"
        rel="noopener noreferrer"
        class="transition-colors hover:!opacity-80"
        style="color: var(--color-text-muted);"
        aria-label="GitHub"
      >
        <svg class="size-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
      </a>
      <a
        href="/rss.xml"
        class="transition-colors hover:!opacity-80"
        style="color: var(--color-text-muted);"
        aria-label="RSS"
      >
        <svg class="size-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M6.18 15.64a2.18 2.18 0 010 4.36 2.18 2.18 0 010-4.36M4 4.44A15.56 15.56 0 0119.56 20h-2.83A12.73 12.73 0 004 7.27V4.44m0 5.66a9.9 9.9 0 019.9 9.9h-2.83A7.07 7.07 0 004 12.93V10.1z"/>
        </svg>
      </a>
    </div>
  </div>
</footer>
