---
import BaseLayout from './BaseLayout.astro';
import TOC from '../components/TOC.astro';

interface Props {
  title: string;
  description?: string;
  date: string;
  tags?: string[];
  headings: { depth: number; slug: string; text: string }[];
}

const { title, description, date, tags, headings } = Astro.props;
const dateObj = new Date(date);
const formattedDate = dateObj.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description}>
  <div class="container py-8">
    <div class="mx-auto grid max-w-6xl gap-10 xl:grid-cols-[1fr_220px]">
      <!-- Article -->
      <article class="min-w-0">
        <header class="mb-8">
          <div class="mb-3 flex flex-wrap items-center gap-3">
            <time
              class="text-sm"
              style="color: var(--color-text-muted);"
              datetime={dateObj.toISOString()}
            >
              {formattedDate}
            </time>
            {tags && tags.length > 0 && (
              <div class="flex flex-wrap gap-2">
                {tags.map((tag) => (
                  <a
                    href={`/tags/${tag}`}
                    class="rounded-full px-2.5 py-0.5 text-xs font-medium transition-colors"
                    style="background: color-mix(in srgb, var(--color-primary) 10%, transparent); color: var(--color-primary);"
                  >
                    {tag}
                  </a>
                ))}
              </div>
            )}
          </div>
          <h1
            class="text-3xl font-bold md:text-4xl"
            style="color: var(--color-text);"
          >
            {title}
          </h1>
          {description && (
            <p
              class="mt-3 text-lg"
              style="color: var(--color-text-secondary);"
            >
              {description}
            </p>
          )}
        </header>

        <div class="prose">
          <slot />
        </div>

        <!-- Back to blog -->
        <div class="mt-12 pt-8" style="border-top: 1px solid var(--color-border);">
          <a
            href="/blog"
            class="inline-flex items-center gap-2 text-sm font-medium"
            style="color: var(--color-primary);"
          >
            ← 返回博客列表
          </a>
        </div>
      </article>

      <!-- TOC sidebar -->
      <TOC headings={headings} />
    </div>
  </div>
</BaseLayout>
